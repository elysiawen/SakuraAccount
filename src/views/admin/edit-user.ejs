<%- include('../layouts/header', {title: title}) %>

<div class="container py-4">
  <div class="row">
    <!-- 侧边栏 -->
    <div class="col-md-3 mb-4">
      <div class="card shadow-sm">
        <div class="card-body text-center">
          <img src="<%= targetUser.avatarUrl %>" alt="<%= targetUser.nickname %>" class="rounded-circle img-thumbnail mb-3" style="width: 120px; height: 120px; object-fit: cover;">
          <h5 class="card-title"><%= targetUser.nickname %></h5>
          <p class="text-muted">@<%= targetUser.username %></p>
          <div class="d-grid">
            <% if (targetUser.role === 'admin') { %>
              <span class="badge bg-danger mb-2">管理员</span>
              <% }else{ %>
                <span class="badge bg-secondary">普通用户</span>
              <% } %>
          </div>
        </div>
      </div>
    </div>
    
    <!-- 主要内容 -->
    <div class="col-md-9">
      <div class="card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
          <h5 class="card-title mb-0">编辑用户</h5>
          <a href="/admin/users/<%= targetUser.userId %>" class="btn btn-sm btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> 返回用户详情
          </a>
        </div>
        <div class="card-body">
          <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger">
              <ul class="mb-0">
                <% errors.forEach(function(error) { %>
                  <li><%= error.msg %></li>
                <% }); %>
              </ul>
            </div>
          <% } %>
          
          <form action="/admin/users/<%= targetUser.userId %>/edit" method="POST">
            <div class="row">
              <div class="col-md-6 mb-3">
                <label for="username" class="form-label">用户名</label>
                <input type="text" class="form-control" id="username" value="<%= targetUser.username %>" disabled>
                <small class="text-muted">用户名创建后不可更改</small>
              </div>
              
              <div class="col-md-6 mb-3">
                <label for="nickname" class="form-label">昵称</label>
                <input type="text" class="form-control" id="nickname" name="nickname" value="<%= targetUser.nickname %>" required>
              </div>
            </div>
            
            <div class="mb-3">
              <label for="email" class="form-label">电子邮箱</label>
              <input type="email" class="form-control" id="email" name="email" value="<%= targetUser.email %>" required>
            </div>
            
            <div class="row">
              <div class="col-md-6 mb-3">
                <label for="role" class="form-label">用户角色</label>
                <select class="form-select" id="role" name="role">
                  <option value="user" <%= targetUser.role === 'user' ? 'selected' : '' %>>普通用户</option>
                  <option value="admin" <%= targetUser.role === 'admin' ? 'selected' : '' %>>管理员</option>
                </select>
              </div>
              
              <div class="col-md-6 mb-3">
                <label for="status" class="form-label">账号状态</label>
                <select class="form-select" id="status" name="status">
                  <option value="active" <%= targetUser.status === 'active' ? 'selected' : '' %>>活跃</option>
                  <option value="inactive" <%= targetUser.status === 'inactive' ? 'selected' : '' %>>未激活</option>
                  <option value="banned" <%= targetUser.status === 'banned' ? 'selected' : '' %>>已禁用</option>
                </select>
              </div>
            </div>
            
            <div class="mb-3">
              <label for="password" class="form-label">重置密码</label>
              <input type="password" class="form-control" id="password" name="password">
              <small class="text-muted">如果不需要重置密码，请留空</small>
            </div>
            
            <hr class="my-4">
            
            <div class="d-flex justify-content-between">
              <a href="/admin/users" class="btn btn-outline-secondary">
                <i class="fas fa-times me-1"></i> 取消
              </a>
              <button type="submit" class="btn btn-primary">
                <i class="fas fa-save me-1"></i> 保存更改
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../layouts/footer') %>