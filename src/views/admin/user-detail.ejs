<%- include('../layouts/header', {title: title}) %>

<div class="container py-4">
  <div class="row">
    <!-- 侧边栏 -->
    <div class="col-md-3 mb-4">
      <div class="card shadow-sm">
        <div class="card-body text-center">
          <img src="<%= targetUser.avatarUrl %>" alt="<%= targetUser.nickname %>" class="rounded-circle img-thumbnail mb-3" style="width: 120px; height: 120px; object-fit: cover;">
          <h5 class="card-title"><%= targetUser.nickname %></h5>
          <p class="text-muted">@<%= targetUser.username %></p>
          <div class="d-grid">
            <% if (targetUser.role === 'admin') { %>
              <span class="badge bg-danger mb-2">管理员</span>
              <% }else{ %>
                <span class="badge bg-secondary">普通用户</span>
              <% } %>
          </div>
        </div>
      </div>
    </div>
    
    <!-- 主要内容 -->
    <div class="col-md-9">
      <div class="card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
          <h5 class="card-title mb-0">用户详情</h5>
          <div>
            <a href="/admin/users/<%= targetUser.userId %>/edit" class="btn btn-sm btn-primary me-2">
              <i class="fas fa-edit me-1"></i> 编辑用户
            </a>
            <a href="/admin/users" class="btn btn-sm btn-outline-secondary">
              <i class="fas fa-arrow-left me-1"></i> 返回列表
            </a>
          </div>
        </div>
        <div class="card-body">
          <!-- 用户基本信息 -->
          <div class="row mb-4">
            <div class="col-md-12">
              <h6 class="border-bottom pb-2 mb-3">基本信息</h6>
            </div>
            <div class="col-md-6">
              <div class="mb-3">
                <label class="form-label text-muted">用户ID</label>
                <p class="form-control-plaintext"><%= targetUser.userId %></p>
              </div>
              <div class="mb-3">
                <label class="form-label text-muted">用户名</label>
                <p class="form-control-plaintext"><%= targetUser.username %></p>
              </div>
              <div class="mb-3">
                <label class="form-label text-muted">昵称</label>
                <p class="form-control-plaintext"><%= targetUser.nickname %></p>
              </div>
            </div>
            <div class="col-md-6">
              <div class="mb-3">
                <label class="form-label text-muted">电子邮箱</label>
                <p class="form-control-plaintext"><%= targetUser.email %></p>
              </div>
              <div class="mb-3">
                <label class="form-label text-muted">用户角色</label>
                <p class="form-control-plaintext">
                  <% if (targetUser.role === 'admin') { %>
                    <span class="badge bg-danger">管理员</span>
                  <% } else { %>
                    <span class="badge bg-secondary">普通用户</span>
                  <% } %>
                </p>
              </div>
              <div class="mb-3">
                <label class="form-label text-muted">账号状态</label>
                <p class="form-control-plaintext">
                  <% if (targetUser.status === 'active') { %>
                    <span class="badge bg-success">活跃</span>
                  <% } else if (targetUser.status === 'inactive') { %>
                    <span class="badge bg-warning text-dark">未激活</span>
                  <% } else if (targetUser.status === 'banned') { %>
                    <span class="badge bg-danger">已禁用</span>
                  <% } %>
                </p>
              </div>
            </div>
          </div>
          
          <!-- 时间信息 -->
          <div class="row mb-4">
            <div class="col-md-12">
              <h6 class="border-bottom pb-2 mb-3">时间信息</h6>
            </div>
            <div class="col-md-6">
              <div class="mb-3">
                <label class="form-label text-muted">注册时间</label>
                <p class="form-control-plaintext"><%= new Date(targetUser.createdAt).toLocaleString() %></p>
              </div>
            </div>
            <div class="col-md-6">
              <div class="mb-3">
                <label class="form-label text-muted">最后登录时间</label>
                <p class="form-control-plaintext"><%= targetUser.lastLoginAt ? new Date(targetUser.lastLoginAt).toLocaleString() : '从未登录' %></p>
              </div>
            </div>
          </div>
          
          <!-- 登录历史 -->
          <div class="row">
            <div class="col-md-12">
              <h6 class="border-bottom pb-2 mb-3">最近登录记录</h6>
              <% if (loginHistory && loginHistory.length > 0) { %>
                <div class="table-responsive">
                  <table class="table table-hover table-striped">
                    <thead class="table-light">
                      <tr>
                        <th>时间</th>
                        <th>IP地址</th>
                        <th>状态</th>
                        <th>设备信息</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% loginHistory.forEach(function(log) { %>
                        <tr>
                          <td><%= new Date(log.loginAt).toLocaleString() %></td>
                          <td><%= log.ipAddress || '-' %></td>
                          <td>
                            <% if (log.status === 'success') { %>
                              <span class="badge bg-success">成功</span>
                            <% } else { %>
                              <span class="badge bg-danger">失败</span>
                              <small class="text-muted"><%= log.failReason %></small>
                            <% } %>
                          </td>
                          <td>
                            <small class="text-truncate d-inline-block" style="max-width: 250px;" title="<%= log.userAgent %>"><%= log.userAgent || '-' %></small>
                          </td>
                        </tr>
                      <% }); %>
                    </tbody>
                  </table>
                </div>
              <% } else { %>
                <div class="alert alert-info">暂无登录记录</div>
              <% } %>
            </div>
          </div>
          
          <hr class="my-4">
          
          <!-- 操作按钮 -->
          <div class="d-flex justify-content-between">
            <div>
              <a href="/admin/users" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i> 返回用户列表
              </a>
            </div>
            <div>
              <a href="/admin/users/<%= targetUser.userId %>/edit" class="btn btn-primary me-2">
                <i class="fas fa-edit me-1"></i> 编辑用户
              </a>
              <% if (targetUser.status !== 'banned') { %>
                <a href="#" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#banUserModal">
                  <i class="fas fa-ban me-1"></i> 禁用账号
                </a>
              <% } else { %>
                <a href="#" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#activateUserModal">
                  <i class="fas fa-check-circle me-1"></i> 激活账号
                </a>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- 禁用用户确认模态框 -->
<div class="modal fade" id="banUserModal" tabindex="-1" aria-labelledby="banUserModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="banUserModalLabel">确认禁用用户</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p>您确定要禁用用户 <strong><%= targetUser.username %></strong> 的账号吗？</p>
        <p class="text-danger">禁用后，该用户将无法登录系统。</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
        <a href="/admin/users/<%= targetUser.userId %>/ban" class="btn btn-danger">确认禁用</a>
      </div>
    </div>
  </div>
</div>

<!-- 激活用户确认模态框 -->
<div class="modal fade" id="activateUserModal" tabindex="-1" aria-labelledby="activateUserModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="activateUserModalLabel">确认激活用户</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p>您确定要激活用户 <strong><%= targetUser.username %></strong> 的账号吗？</p>
        <p class="text-success">激活后，该用户将可以正常登录系统。</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
        <a href="/admin/users/<%= targetUser.userId %>/activate" class="btn btn-success">确认激活</a>
      </div>
    </div>
  </div>
</div>

<%- include('../layouts/footer') %>