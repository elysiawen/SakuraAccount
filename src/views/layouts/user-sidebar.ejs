<!-- 用户侧边栏 -->
<div class="col-md-3 mb-4">
  <div class="card shadow-sm">
    <div class="card-body text-center">
      <img src="<%= user.avatarUrl %>" alt="<%= user.nickname %>" class="rounded-circle img-thumbnail mb-3" style="width: 120px; height: 120px; object-fit: cover;">
      <h5 class="card-title"><%= user.nickname %></h5>
      <p class="text-muted">@<%= user.username %></p>
      <div class="d-grid gap-2">
        <a href="/user/profile" class="btn btn-outline-primary">编辑资料</a>
        <a href="/user/avatar" class="btn btn-outline-secondary">更换头像</a>
      </div>
    </div>
    <div class="list-group list-group-flush">
      <a href="/user/dashboard" class="list-group-item list-group-item-action <%= activePage === 'dashboard' ? 'active' : '' %>">
        <i class="fas fa-tachometer-alt me-2"></i> 个人中心
      </a>
      <a href="/user/profile" class="list-group-item list-group-item-action <%= activePage === 'profile' ? 'active' : '' %>">
        <i class="fas fa-user me-2"></i> 个人资料
      </a>
      <a href="/user/change-password" class="list-group-item list-group-item-action <%= activePage === 'change-password' ? 'active' : '' %>">
        <i class="fas fa-key me-2"></i> 修改密码
      </a>
      <a href="/user/applications" class="list-group-item list-group-item-action <%= activePage === 'applications' ? 'active' : '' %>">
        <i class="fas fa-cube me-2"></i> 我的应用
      </a>
      <a href="/auth/logout" class="list-group-item list-group-item-action text-danger">
        <i class="fas fa-sign-out-alt me-2"></i> 退出登录
      </a>
    </div>
  </div>
</div>