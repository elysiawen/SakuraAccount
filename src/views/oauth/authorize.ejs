<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Sakura Network账号中心</title>
  
  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Font Awesome -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <!-- 自定义样式 -->
  <link href="/public/css/style.css" rel="stylesheet">

  <style>
    /* 背景设置 */
    body {
      background: url('https://api.suyanw.cn/api/comic') no-repeat center center fixed;
      background-size: cover;
      position: relative;
      min-height: 100vh;
      opacity: 0;
      animation: fadeIn 0.8s ease-out forwards;
    }
    
    /* 叠加一个黑色半透明遮罩 */
    body::before {
      content: "";
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.5);
      -webkit-backdrop-filter: blur(5px);
      -moz-backdrop-filter: blur(5px);
      -ms-backdrop-filter: blur(5px);
      -o-backdrop-filter: blur(5px);
      backdrop-filter: blur(5px);
      z-index: -1;
      pointer-events: none;
    }

    /* 高斯模糊导航栏 */
    .navbar {
      background: rgba(255, 255, 255, 0.2) !important;
      -webkit-backdrop-filter: blur(10px);
      -moz-backdrop-filter: blur(10px);
      backdrop-filter: blur(10px);
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
      position: relative;
      z-index: 10;
    }

    /* 头像样式 */
    .avatar-sm {
      width: 32px;
      height: 32px;
    }

    /* 卡片阴影和动画 */
    .card {
      border-radius: 12px;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
      overflow: hidden;
      opacity: 0;
      transform: translateY(20px);
      animation: slideUp 0.6s ease-out 0.4s forwards;
    }

    /* 授权按钮 */
    .btn-auth {
      width: 48%;
      padding: 10px 0;
      font-size: 1.1rem;
      opacity: 0;
      transform: translateY(10px);
      animation: slideUp 0.4s ease-out 1s forwards;
    }

    /* 权限列表项动画 */
    .list-group-item {
      opacity: 0;
      transform: translateX(-10px);
      animation: slideIn 0.4s ease-out forwards;
    }

    .list-group-item:nth-child(1) { animation-delay: 0.6s; }
    .list-group-item:nth-child(2) { animation-delay: 0.7s; }
    .list-group-item:nth-child(3) { animation-delay: 0.8s; }

    /* 动画关键帧定义 */
    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    @keyframes slideUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateX(-10px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }
    
  </style>
</head>
<body>
  <!-- 导航栏 -->
  <nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container">
      <a class="navbar-brand fw-bold">Sakura Network</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto"></ul>
        <ul class="navbar-nav">
          <% if (locals.user) { %>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="navbarDropdown" data-bs-toggle="dropdown">
                <img src="<%= locals.user.avatarUrl %>" alt="头像" class="avatar-sm rounded-circle me-2">
                <span><%= locals.user.nickname %></span>
              </a>
              <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" href="/user/profile">个人资料</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-danger" href="/auth/logout">退出登录</a></li>
              </ul>
            </li>
          <% } else { %>
            <li class="nav-item"><a class="nav-link" href="/auth/login">登录</a></li>
            <li class="nav-item"><a class="nav-link" href="/auth/register">注册</a></li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <!-- 授权界面 -->
  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-md-8">
        <div class="card">
          <div class="card-header bg-primary text-white text-center">
            <h4 class="mb-0">授权请求</h4>
          </div>
          <div class="card-body p-4">
            <div class="text-center mb-4">
              <% if (client.logoUrl) { %>
                <img src="<%= client.logoUrl %>" alt="<%= client.name %>" class="app-logo mb-3">
              <% } else { %>
                <i class="fas fa-shield-alt fa-4x text-primary mb-3"></i>
              <% } %>
              <h3 class="fw-bold"><%= client.name %></h3>
              <p class="text-muted"><%= client.websiteUrl || '' %></p>
            </div>

            <div class="alert alert-info alert-permanent">
              <p class="mb-0"><strong><%= client.name %></strong> 请求访问您的账号信息。</p>
            </div>

            <h5>将获得以下权限：</h5>
            <ul class="list-group mb-4">
              <% if (scope.includes('profile')) { %>
                <li class="list-group-item"><i class="fas fa-user me-2 text-primary"></i> 访问您的个人资料信息</li>
              <% } %>
              <% if (scope.includes('email')) { %>
                <li class="list-group-item"><i class="fas fa-envelope me-2 text-primary"></i> 访问您的电子邮箱地址</li>
              <% } %>
              <% if (scope.includes('openid')) { %>
                <li class="list-group-item"><i class="fas fa-id-card me-2 text-primary"></i> 验证您的身份</li>
              <% } %>
            </ul>

            <form action="/oauth/authorize/decision" method="POST" class="text-center">
              <input type="hidden" name="client_id" value="<%= client.clientId %>">
              <input type="hidden" name="redirect_uri" value="<%= redirect_uri %>">
              <input type="hidden" name="response_type" value="<%= response_type %>">
              <input type="hidden" name="scope" value="<%= scope %>">
              <% if (state) { %>
                <input type="hidden" name="state" value="<%= state %>">
              <% } %>

              <div class="d-flex justify-content-between">
                <button type="submit" name="approved" value="false" class="btn btn-outline-danger btn-auth">
                  <i class="fas fa-times me-1"></i> 拒绝
                </button>
                <button type="submit" name="approved" value="true" class="btn btn-primary btn-auth">
                  <i class="fas fa-check me-1"></i> 授权
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!-- Bootstrap JS Bundle with Popper -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <!-- 自定义脚本 -->
  <script src="/public/js/main.js"></script>
</body>
</html>
