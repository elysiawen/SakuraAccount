<%- include('../layouts/header', {title: title}) %>

<div class="container py-4">
  <div class="row">
    <!-- 侧边栏 -->
    <%- include('../layouts/user-sidebar', {user: user, activePage: 'profile'}) %>
    
    <!-- 主要内容 -->
    <div class="col-md-9">
      <div class="card shadow-sm">
        <div class="card-header bg-white">
          <h5 class="card-title mb-0">编辑个人资料</h5>
        </div>
        <div class="card-body">
          <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger">
              <ul class="mb-0">
                <% errors.forEach(function(error) { %>
                  <li><%= error.msg %></li>
                <% }); %>
              </ul>
            </div>
          <% } %>
          
          <form action="/user/profile" method="POST">
            <div class="mb-3">
              <label for="username" class="form-label">用户名</label>
              <input type="text" class="form-control" id="username" value="<%= user.username %>" disabled>
              <small class="text-muted">用户名创建后不可更改</small>
            </div>
            
            <div class="mb-3">
              <label for="nickname" class="form-label">昵称</label>
              <input type="text" class="form-control" id="nickname" name="nickname" value="<%= user.nickname %>" required>
            </div>
            
            <div class="mb-3">
              <label for="email" class="form-label">电子邮箱</label>
              <input type="email" class="form-control" id="email" name="email" value="<%= user.email %>" required>
            </div>
            
            <div class="d-grid gap-2">
              <button type="submit" class="btn btn-primary">保存更改</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../layouts/footer') %>