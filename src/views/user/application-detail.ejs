  </div>
</div>

<!-- 编辑应用模态框 -->
<div class="modal fade" id="editAppModal" tabindex="-1" aria-labelledby="editAppModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="editAppModalLabel">编辑应用</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="/user/applications/<%= application.clientId %>/update" method="POST" enctype="multipart/form-data">
        <div class="modal-body">
          <div class="mb-3">
            <label for="appName" class="form-label">应用名称 <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="appName" name="name" value="<%= application.name %>" required>
          </div>
          
          <div class="mb-3">
            <label for="appLogo" class="form-label">应用图标</label>
            <div class="d-flex align-items-center mb-2">
              <% if (application.logoUrl) { %>
                <img src="<%= application.logoUrl %>" alt="当前图标" class="me-3 rounded" style="width: 64px; height: 64px; object-fit: cover;">
              <% } else { %>
                <div class="me-3 bg-light rounded d-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">
                  <i class="fas fa-cube text-primary"></i>
                </div>
              <% } %>
              <div>
                <% if (application.logoUrl) { %>
                  <p class="mb-0 small">当前图标</p>
                <% } else { %>
                  <p class="mb-0 small">无图标</p>
                <% } %>
              </div>
            </div>
            <input type="file" class="form-control" id="appLogo" name="logo" accept="image/png,image/jpeg,image/gif">
            <small class="text-muted">推荐尺寸：128x128像素，支持PNG、JPEG、GIF格式</small>
          </div>
          
          <div class="mb-3">
            <label for="appDescription" class="form-label">应用描述</label>
            <textarea class="form-control" id="appDescription" name="description" rows="3"><%= application.description || '' %></textarea>
          </div>
          
          <div class="mb-3">
            <label for="appWebsiteUrl" class="form-label">应用网站 <span class="text-danger">*</span></label>
            <input type="url" class="form-control" id="appWebsiteUrl" name="websiteUrl" value="<%= application.websiteUrl %>" required>
          </div>
          
          <div class="mb-3">
            <label for="appRedirectUris" class="form-label">重定向URI <span class="text-danger">*</span></label>
            <textarea class="form-control" id="appRedirectUris" name="redirectUris" rows="2" required><%= application.redirectUris.join('\n') %></textarea>
            <small class="text-muted">多个URL请用换行分隔</small>
          </div>
          
          <div class="mb-3">
            <label class="form-label">应用状态</label>
            <div class="form-check">
              <input class="form-check-input" type="radio" name="status" id="statusActive" value="active" <%= application.status === 'active' ? 'checked' : '' %>>
              <label class="form-check-label" for="statusActive">
                活跃 - 应用可以正常使用
              </label>
            </div>
            <div class="form-check">
              <input class="form-check-input" type="radio" name="status" id="statusDisabled" value="disabled" <%= application.status === 'disabled' ? 'checked' : '' %>>
              <label class="form-check-label" for="statusDisabled">
                禁用 - 暂时停用应用
              </label>
            </div>
          </div>
          
          <div class="mb-3">
            <label class="form-label">授权类型</label>
            <% ['authorization_code', 'implicit', 'client_credentials', 'password', 'refresh_token'].forEach(function(type) { %>
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="grantTypes" id="<%= type %>" value="<%= type %>" <%= application.allowedGrantTypes.includes(type) ? 'checked' : '' %>>
                <label class="form-check-label" for="<%= type %>">
                  <% if (type === 'authorization_code') { %>
                    授权码（推荐）
                  <% } else if (type === 'implicit') { %>
                    隐式授权
                  <% } else if (type === 'client_credentials') { %>
                    客户端凭证
                  <% } else if (type === 'password') { %>
                    密码授权
                  <% } else if (type === 'refresh_token') { %>
                    refresh_token
                  <% } %>
                </label>
              </div>
            <% }); %>
          </div>
          
          <div class="mb-3">
            <label class="form-label">请求权限</label>
            <% ['profile', 'email', 'openid'].forEach(function(scope) { %>
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="scopes" id="scope<%= scope %>" value="<%= scope %>" <%= application.allowedScopes.includes(scope) ? 'checked' : '' %>>
                <label class="form-check-label" for="scope<%= scope %>">
                  <% if (scope === 'profile') { %>
                    个人资料
                  <% } else if (scope === 'email') { %>
                    电子邮箱
                  <% } else if (scope === 'openid') { %>
                    OpenID Connect身份验证
                  <% } %>
                </label>
              </div>
            <% }); %>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
          <button type="submit" class="btn btn-primary">保存更改</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- 删除应用模态框 -->
<div class="modal fade" id="deleteAppModal" tabindex="-1" aria-labelledby="deleteAppModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="deleteAppModalLabel">删除应用</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p>您确定要删除应用 <strong><%= application.name %></strong> 吗？</p>
        <div class="alert alert-danger">
          <i class="fas fa-exclamation-triangle me-2"></i> 警告：此操作不可逆，将删除所有相关的授权和令牌。
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
        <form action="/user/applications/<%= application.clientId %>/delete" method="POST">
          <button type="submit" class="btn btn-danger">确认删除</button>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
// 复制到剪贴板函数
function copyToClipboard(button) {
  const textToCopy = button.getAttribute('data-copy');
  navigator.clipboard.writeText(textToCopy).then(() => {
    // 临时改变按钮样式表示复制成功
    const originalHTML = button.innerHTML;
    button.innerHTML = '<i class="fas fa-check"></i>';
    button.classList.add('btn-success');
    button.classList.remove('btn-outline-secondary');
    
    setTimeout(() => {
      button.innerHTML = originalHTML;
      button.classList.remove('btn-success');
      button.classList.add('btn-outline-secondary');
    }, 1000);
  }).catch(err => {
    console.error('复制失败:', err);
  });
}
</script>

