<%- include('layouts/header', {title: title}) %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-8 text-center">
      <h1 class="display-4 mb-4">欢迎使用 Sakura Network 账号中心</h1>
      <p class="lead mb-4">统一管理您在 Sakura Network 旗下所有服务的账号信息</p>
      
      <div class="row mt-5">
        <div class="col-md-6 mb-3">
          <div class="card h-100 shadow-sm">
            <div class="card-body text-center py-4">
              <i class="fas fa-user-circle fa-4x text-primary mb-3"></i>
              <h3 class="card-title">账号管理</h3>
              <p class="card-text">管理您的个人资料、密码和安全设置</p>
              <% if (locals.user) { %>
                <a href="/user/dashboard" class="btn btn-primary">进入个人中心</a>
              <% } else { %>
                <a href="/auth/login" class="btn btn-primary">立即登录</a>
              <% } %>
            </div>
          </div>
        </div>
        
        <div class="col-md-6 mb-3">
          <div class="card h-100 shadow-sm">
            <div class="card-body text-center py-4">
              <i class="fas fa-shield-alt fa-4x text-primary mb-3"></i>
              <h3 class="card-title">安全保障</h3>
              <p class="card-text">采用先进的加密技术保护您的账号安全</p>
              <% if (!locals.user) { %>
                <a href="/auth/register" class="btn btn-primary">立即注册</a>
              <% } else { %>
                <a href="/user/change-password" class="btn btn-primary">修改密码</a>
              <% } %>
            </div>
          </div>
        </div>
      </div>
      
      <div class="row mt-4">
        <div class="col-md-6 mb-3">
          <div class="card h-100 shadow-sm">
            <div class="card-body text-center py-4">
              <i class="fas fa-sync fa-4x text-primary mb-3"></i>
              <h3 class="card-title">统一登录</h3>
              <p class="card-text">一次登录，畅享所有 Sakura Network 服务</p>
            </div>
          </div>
        </div>
        
        <div class="col-md-6 mb-3">
          <div class="card h-100 shadow-sm">
            <div class="card-body text-center py-4">
              <i class="fas fa-history fa-4x text-primary mb-3"></i>
              <h3 class="card-title">登录历史</h3>
              <p class="card-text">查看您的账号登录记录，保障账号安全</p>
              <% if (locals.user) { %>
                <a href="/user/dashboard" class="btn btn-primary">查看记录</a>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('layouts/footer') %>