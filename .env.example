# ============================================
# Sakura Network Account Center 配置文件
# 复制本文件为 .env 并根据实际情况修改
# ============================================

# --- 服务配置 ---
NODE_ENV=development
PORT=3000

# --- 数据库配置 ---
# 可选值: sqlite, mysql, mariadb
DB_TYPE=sqlite

# SQLite 配置
SQLITE_FILE=./data/database.sqlite

# MySQL / MariaDB 配置（DB_TYPE 为 mysql 或 mariadb 时生效）
# DB_NAME=sakura_account
# DB_USER=root
# DB_PASSWORD=your_password
# DB_HOST=localhost
# DB_PORT=3306

# --- 会话配置 ---
# 生产环境请务必修改为随机复杂字符串
SESSION_SECRET=sakura_network_secret_key

# --- JWT 配置 ---
# 签名算法: HS256 或 RS256
JWT_ALG=HS256

# HS256 模式使用的密钥（生产环境请修改）
JWT_SECRET=sakura_network_jwt_secret_key

# RS256 模式配置（JWT_ALG=RS256 时生效）
# PRIVATE_KEY_PATH=src/keys/private_key.pem
# PUBLIC_KEY_PATH=src/keys/public_key.pem
# JWT_KID=your_key_id

# --- OpenID Connect 配置 ---
# 设置为你的实际域名，如 https://account.example.com
OPENID_ISSUER=http://127.0.0.1:3000

# --- 文件上传配置 ---
UPLOAD_DIR=./public/uploads
# 最大上传文件大小（字节），默认 5MB
MAX_FILE_SIZE=5242880
