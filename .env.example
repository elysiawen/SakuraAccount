# Database Configuration
# Supported: postgres, mysql
DB_TYPE=postgres

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sakura_account
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=sakura_account
MYSQL_USER=root
MYSQL_PASSWORD=your_password

# Application
APP_NAME=Sakura Account
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_SECRET=your-secret-key-change-this-in-production

# OAuth2 Provider
OAUTH2_ISSUER=http://localhost:3000
OAUTH2_ACCESS_TOKEN_EXPIRY=3600
OAUTH2_AUTHORIZATION_CODE_EXPIRY=600

# Session
SESSION_EXPIRY=604800

# WebAuthn
WEBAUTHN_RP_NAME=Sakura Account
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# Optional: Analytics (leave empty to disable)
# UMAMI_WEBSITE_ID=
# UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
# GOOGLE_ANALYTICS_ID=
# CLARITY_ID=

# Optional: Dashboard banner background (image URL or API)
# BANNER_BACKGROUND_URL=https://example.com/banner.jpg
